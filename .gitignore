# ============================================
# YOLO知识库 - Git忽略规则配置
# ============================================

# ---- Obsidian 个人配置（不应公开）----
.obsidian/workspace.json
.obsidian/app.json
.obsidian/plugins/
.obsidian/themes/
.plugins/

# ---- Trae 工具内部文件（开发工具配置）----
.trae/

# ---- Python 相关 ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
env/
venv/
ENV/
.venv/
python-env*/

# ---- 操作系统生成文件 ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---- 编辑器/IDE 配置 ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# ---- 临时文件 ----
*.tmp
*.temp
*.bak
*.log
*.cache
npm-debug.log*

# ---- Jupyter Notebook ----
.ipynb_checkpoints/

# ---- 数据文件（大文件或敏感数据）----
*.csv
*.xlsx
*.xls
!examples/**/*.csv

# 模型权重文件（通常很大）
*.pt
*.pth
*.onnx
*.engine
*.bin
!pretrained/*.yaml

# 数据集（通常很大）
datasets/
data/raw/
data/processed/

# ---- 文档构建输出 ----
site/
_build/
dist/

# ---- 包管理器 ----
node_modules/
package-lock.json
yarn.lock

# ---- 环境变量（可能包含密钥）----
.env
.env.local
.env.*.local

# ============================================
# 白名单：确保以下文件被跟踪
# ============================================
# 这些规则确保重要文件不会被意外忽略
!YOLO使用和优化/**/*.md
!yolo-knowledge-web/**/*
!README.md
!LICENSE
!.gitignore
!docs/**/*.md
